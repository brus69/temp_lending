# Скопируйте в .env при необходимости (docker compose подхватывает .env автоматически)

DJANGO_SECRET_KEY=change-me-in-production
DJANGO_DEBUG=0
# Название магазина на витрине (логотип, каталог /category/)
# DJANGO_STORE_NAME=Все инструменты
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,web
DJANGO_SERVE_MEDIA=1
DJANGO_COLLECTSTATIC=1

# SQLite (docker-compose.yml по умолчанию)
# SQLITE_PATH задаётся в compose: /data/db.sqlite3

# PostgreSQL (docker-compose.postgres.yml)
# DJANGO_USE_POSTGRES=1
# POSTGRES_DB=lending
# POSTGRES_USER=lending
# POSTGRES_PASSWORD=lending

# Доверенные источники для CSRF за HTTPS-прокси (через запятую)
# DJANGO_CSRF_TRUSTED_ORIGINS=https://example.com
